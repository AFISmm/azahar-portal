# Variables de entorno de Portal Azahar.
# Cópialas a ".env.local" y complétalas para activar el backend real (Vercel
# Postgres + autenticación propia). Si VITE_ENABLE_BACKEND no es "true", la
# aplicación funciona automáticamente en "modo demo" con datos en memoria
# (ver src/lib/dataSource.ts).

# Variable de cliente (Vite): actívala solo cuando ya hayas configurado
# Postgres en Vercel (ver README.md, "Activar backend real con Vercel Postgres").
# Mientras no sea exactamente "true", la app corre en modo demo.
VITE_ENABLE_BACKEND=

# ----------------------------------------------------------------------------
# Las siguientes variables son EXCLUSIVAMENTE del servidor: nunca deben llevar
# el prefijo VITE_ ni definirse en un archivo de entorno que el cliente pueda
# leer. Se configuran directamente en el proyecto de Vercel (Project Settings
# -> Environment Variables). Solo son necesarias en ".env.local" para
# desarrollo local, y en ese caso se obtienen con `vercel env pull .env.local`
# (no las escribas a mano si ya usas ese comando).
# ----------------------------------------------------------------------------

# Se define sola al conectar un almacenamiento Postgres (Neon) a este proyecto
# en el dashboard de Vercel (Project -> Storage -> Create Database). No hace
# falta copiarla manualmente en producción.
# POSTGRES_URL=

# Firma la cookie de sesión (JWT). Genera un valor con: openssl rand -hex 32
# AUTH_SECRET=

# Habilita el chatbot del portal (api/chat.ts). Crea una llave gratuita en
# https://aistudio.google.com/apikey (cuenta de Google, sin tarjeta). Sin
# esta variable, el widget de chat sigue apareciendo pero avisa que el
# asistente no está activado todavía.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# La voz de JARVIS usa la síntesis de voz gratuita del navegador (Web Speech
# API): no requiere ninguna variable de entorno. Cada persona puede elegir su
# voz en español preferida (entre las que su sistema tenga instaladas) desde
# el ícono de ajustes dentro del chat.
