# Variables de entorno del cliente (Vite) para Portal Azahar.
# Cópialas a ".env.local" y complétalas para activar el backend real de Supabase.
# Si estas dos variables no están definidas, la aplicación funciona automáticamente
# en "modo demo" con datos en memoria (ver src/lib/dataSource.ts).

VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# IMPORTANTE: SUPABASE_SERVICE_ROLE_KEY NUNCA debe ir en un archivo de entorno del
# cliente ni en este archivo. Esa llave solo se usa desde funciones serverless en
# /api (por ejemplo /api/empleados-crear.ts) y debe configurarse directamente en las
# variables de entorno del proyecto en Vercel (Project Settings -> Environment Variables),
# junto con SUPABASE_URL (la misma URL, disponible también sin el prefijo VITE_).
